# Vertex env — copy to .env.local (frontend) / .env (scripts). NEVER commit real values.

# ButterBase (public app id + api url are safe; api KEY is secret)
NEXT_PUBLIC_BUTTERBASE_API_URL=https://api.butterbase.ai/v1/app_ukesbu2ssy8a
BUTTERBASE_API_KEY=

# Neo4j Aura (server-side only)
NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
